# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron secret (to secure cron endpoints)
CRON_SECRET=your-cron-secret

# Admin panel (protects /admin and /api/admin). ADMIN_PASSWORD is what you
# type on the /admin/login page. ADMIN_SESSION_SECRET signs the session
# cookie — rotate it to invalidate all logged-in browsers.
# Generate a strong secret with:  openssl rand -base64 32
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-32-plus-char-random-string

